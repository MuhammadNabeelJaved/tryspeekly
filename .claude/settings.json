{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(npm *)",
      "Bash(node *)",
      "Bash(npx *)",
      "Read",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(git push --force)"
    ],
    "defaultMode": "default"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // .tool_response.filePath // empty' | { read -r f; [ -n \"$f\" ] && npx prettier --write \"$f\" --ignore-unknown 2>/dev/null || true; }",
            "statusMessage": "Formatting with Prettier..."
          }
        ]
      }
    ]
  },
  "env": {
    "NODE_ENV": "development"
  },
  "cleanupPeriodDays": 30,
  "autoCompactEnabled": true
}
