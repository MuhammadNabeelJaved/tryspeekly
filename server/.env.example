NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173
MONGODB_URI=mongodb://127.0.0.1:27017/english-website
JWT_ACCESS_SECRET=change-this-access-secret-to-at-least-32-characters
JWT_REFRESH_SECRET=change-this-refresh-secret-to-at-least-32-characters
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=10
