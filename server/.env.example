# ── Server environment ────────────────────────────────────────────────────────
# Copy to .env and fill in real secrets. Never commit the real .env.

NODE_ENV=development
PORT=5000
# Production: set to the deployed frontend origin, e.g. https://tryspeekly.com
CLIENT_URL=http://localhost:5173

# ── Site / Brand ──────────────────────────────────────────────────────────────
SITE_URL=https://tryspeekly.com
SITE_NAME=TrySpeekly

# ── Public contact details (single source of truth — used in emails, sitemap, support)
CONTACT_EMAIL=hello@tryspeekly.com
SUPPORT_EMAIL=support@tryspeekly.com
PRIVACY_EMAIL=privacy@tryspeekly.com
PAYMENTS_EMAIL=payments@tryspeekly.com
CONTACT_PHONE=+92 308 692 5545
CONTACT_WHATSAPP=923086925545

# ── Database (MongoDB Atlas) ──────────────────────────────────────────────────
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net
DB_NAME=english

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me
JWT_REFRESH_SECRET=change-me
JWT_ACCESS_EXPIRES_IN=30m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Anthropic (AI chatbot) ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Add & verify tryspeekly.com in resend.com before sending from this address.
RESEND_API_KEY=
RESEND_FROM_EMAIL=TrySpeekly <hello@tryspeekly.com>
