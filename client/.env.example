# ── Client environment (Vite) ─────────────────────────────────────────────────
# Copy to .env and fill in. Vite only exposes vars prefixed with VITE_.
# NOTE: these are baked in at BUILD time — re-run `npm run build` after changing.

# API / realtime (production: your API origin, e.g. https://api.tryspeekly.com)
VITE_API_URL=http://localhost:5000
VITE_SOCKET_URL=http://localhost:5000

# ── Site / Brand ──────────────────────────────────────────────────────────────
VITE_SITE_URL=https://tryspeekly.com
VITE_SITE_NAME=Speekly

# ── Public contact details (single source of truth — change here, then rebuild) ─
VITE_CONTACT_EMAIL=hello@tryspeekly.com
VITE_SUPPORT_EMAIL=support@tryspeekly.com
VITE_PRIVACY_EMAIL=privacy@tryspeekly.com
VITE_PAYMENTS_EMAIL=payments@tryspeekly.com
VITE_CONTACT_PHONE=+92 308 692 5545
VITE_CONTACT_WHATSAPP=923086925545
# Physical address shown in footer/contact/privacy pages. Leave blank to hide it.
VITE_CONTACT_ADDRESS=
